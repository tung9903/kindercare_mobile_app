<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_light">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@color/white"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/layoutActionIcons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chào buổi sáng, "
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTeacherName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cô Lan Anh 👋"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutActionIcons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/layoutNotification"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_input_rounded"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_notification"
                    app:tint="@color/text_main" />

                <View
                    android:id="@+id/viewNotiBadge"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_badge_red"
                    android:visibility="gone" />
            </FrameLayout>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar"
                app:shapeAppearanceOverlay="@style/CircleImageStyle"
                app:strokeColor="@color/border_color"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Attendance Overview Card - REDESIGNED to avoid overlap -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvClassLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="TÌNH HÌNH LỚP MẦM 1"
                        android:textColor="@color/primary_green"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tvClassSizeDash"/>

                    <TextView
                        android:id="@+id/tvClassSizeDash"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="25 bé"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvClassLabel" />

                    <TextView
                        android:id="@+id/tvPresentCountNum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="22"
                        android:textColor="@color/text_main"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvClassLabel" />

                    <TextView
                        android:id="@+id/tvTotalCountNum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/25"
                        android:textColor="@color/text_tertiary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/tvPresentCountNum"
                        app:layout_constraintStart_toEndOf="@id/tvPresentCountNum"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvPresentLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Hiện diện"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="@id/tvTotalCountNum"
                        app:layout_constraintStart_toEndOf="@id/tvTotalCountNum" />

                    <!-- Progress Bar -->
                    <LinearLayout
                        android:id="@+id/layoutProgressBar"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_progress_container"
                        android:orientation="horizontal"
                        android:weightSum="100"
                        app:layout_constraintTop_toBottomOf="@id/tvPresentCountNum">
                        <View
                            android:id="@+id/viewProgressPresent"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="80"
                            android:background="@color/success" />
                        <View
                            android:id="@+id/viewProgressAbsent"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="20"
                            android:background="@color/error" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPresentDash"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="● Có mặt: 22"
                        android:textColor="@color/success"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/tvAbsentDash"
                        app:layout_constraintHorizontal_bias="0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/layoutProgressBar" />

                    <TextView
                        android:id="@+id/tvAbsentDash"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="● Vắng: 03"
                        android:textColor="@color/error"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvPresentDash"
                        app:layout_constraintTop_toTopOf="@id/tvPresentDash" />

                    <View
                        android:id="@+id/dividerDash"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="#F1F5F9"
                        app:layout_constraintTop_toBottomOf="@id/tvPresentDash" />

                    <LinearLayout
                        android:id="@+id/layoutPendingLeave"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_badge_light_green"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toBottomOf="@id/dividerDash">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📝"
                            android:textSize="18sp" />
                        <TextView
                            android:id="@+id/tvPendingLeaveCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="2 đơn xin nghỉ chưa duyệt"
                            android:textColor="@color/dark_green_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <View
                            android:id="@+id/viewLeaveBadge"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_badge_red"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutPillReminder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#EFF6FF"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toBottomOf="@id/layoutPendingLeave">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💊"
                            android:textSize="18sp" />
                        <TextView
                            android:id="@+id/tvPillReminder"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="Đã hoàn thành dặn thuốc hôm nay"
                            android:textColor="#1D4ED8"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <View
                            android:id="@+id/viewPillBadge"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_badge_red"
                            android:visibility="gone" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions Grid -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Tiện ích giáo viên"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="true"
                android:layout_marginBottom="24dp">

                <include layout="@layout/item_dashboard_feature"
                    android:id="@+id/btnFeatureDiemDanhGrid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />

                <include layout="@layout/item_dashboard_feature"
                    android:id="@+id/btnFeatureDanhSachLopGrid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />

                <include layout="@layout/item_dashboard_feature"
                    android:id="@+id/btnFeatureHoatDongGrid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />

                <include layout="@layout/item_dashboard_feature"
                    android:id="@+id/btnFeatureChatGrid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />

                <include layout="@layout/item_dashboard_feature"
                    android:id="@+id/btnFeatureDuyetDonGrid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />

                <include layout="@layout/item_dashboard_feature"
                    android:id="@+id/btnFeatureSucKhoeGrid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />

                <include layout="@layout/item_dashboard_feature"
                    android:id="@+id/btnFeatureNhatKyGrid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />
            </GridLayout>

            <!-- Live Schedule Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lịch trình sinh hoạt"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layoutScheduleTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">
                    <!-- Timeline items added dynamically -->
                </LinearLayout>
            </LinearLayout>

            <!-- Current Meal Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:id="@+id/tvMenuDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thực đơn hôm nay"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_cake" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvMealType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bữa trưa"
                                android:textColor="@color/text_main"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvMealDishes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cơm tấm, canh bí đỏ..."
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/btnViewDetailMenu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xem thêm"
                            android:textColor="@color/primary_green"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/linearLayoutNavGV"
        layout="@layout/layout_bottom_navigation_gv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>