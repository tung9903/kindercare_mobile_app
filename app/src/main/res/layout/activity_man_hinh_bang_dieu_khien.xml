<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".View.GiaoVien.ManHinhBangDieuKhien">

    <!-- Header -->
    <TextView
        android:id="@+id/tvLogoTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="18dp"
        android:text="KinderCare"
        android:textColor="#005A36"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutActionIcons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@+id/tvLogoTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvLogoTitle">

        <ImageView
            android:id="@+id/imgCalendar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Calendar Icon"
            android:src="@drawable/ic_calendar" />

        <FrameLayout
            android:id="@+id/layoutNotification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="28dp"
                android:contentDescription="Notification Icon"
                android:src="@drawable/ic_notification" />

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="2dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_red_thongbao" />
        </FrameLayout>

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="User Avatar"
            android:src="@drawable/avatar" />
    </LinearLayout>

    <!-- Teacher Navigation -->
    <include
        android:id="@+id/linearLayoutNavGV"
        layout="@layout/layout_bottom_navigation_gv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@+id/linearLayoutNavGV"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvLogoTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F8FAFC"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- SECTION 1: TÌNH HÌNH LỚP HỌC -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tình hình lớp học"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPresentCountNum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textColor="#00B16A"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTotalCountNum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/00"
                            android:textColor="#555555"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="14dp"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="7dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/viewProgressPresent"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="#00B16A" />

                            <View
                                android:id="@+id/viewProgressAbsent"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0"
                                android:background="#EF4836" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Chỉ số chi tiết dưới ProgressBar - Sử dụng LinearLayout phân cột tránh chồng đè -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvPresentDash"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● Có mặt: 00"
                            android:textColor="#555555"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="12dp"
                            android:layout_marginHorizontal="10dp"
                            android:background="#DDDDDD" />

                        <TextView
                            android:id="@+id/tvAbsentDash"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="● Vắng: 0 (0 phép)"
                            android:textColor="#555555"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvClassSizeDash"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00 bé"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="12dp"
                        android:background="#F2F4F7" />

                    <!-- Mục thông báo đơn nghỉ -->
                    <LinearLayout
                        android:id="@+id/layoutPendingLeave"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rounded_orange"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_bell"
                            app:tint="#D35400" />

                        <TextView
                            android:id="@+id/tvPendingLeaveCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="Có 0 đơn xin nghỉ đang chờ duyệt"
                            android:textColor="#D35400"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="➔"
                            android:textColor="#D35400"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Mục dặn thuốc -->
                    <LinearLayout
                        android:id="@+id/layoutPillReminder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_rounded_blue"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_pill"
                            app:tint="#2980B9" />

                        <TextView
                            android:id="@+id/tvPillReminder"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="Số bé cần uống thuốc hôm nay"
                            android:textColor="#2980B9"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="➔"
                            android:textColor="#2980B9"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnProcessAttendance"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="Xử lý &amp; Điểm danh ngay →"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp"
                        app:backgroundTint="#1976D2" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 2: GRID CHỨC NĂNG -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false"
                android:layout_marginHorizontal="8dp"
                android:layout_marginBottom="20dp">

                <!-- Row 1 -->
                <LinearLayout
                    android:id="@+id/btnFeatureDiemDanhGrid"
                    style="@style/FeatureItemStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_attendance"/>
                    <TextView style="@style/FeatureTextStyle" android:text="Điểm danh"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnFeatureDanhSachLopGrid"
                    style="@style/FeatureItemStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_class_list"/>
                    <TextView style="@style/FeatureTextStyle" android:text="Danh sách lớp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnFeatureHoatDongGrid"
                    style="@style/FeatureItemStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_activity"/>
                    <TextView style="@style/FeatureTextStyle" android:text="Hoạt động"/>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:id="@+id/btnFeatureChatGrid"
                    style="@style/FeatureItemStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_chat"/>
                    <TextView style="@style/FeatureTextStyle" android:text="Chat phụ huynh"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnFeatureDuyetDonGrid"
                    style="@style/FeatureItemStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_calendar"/>
                    <TextView style="@style/FeatureTextStyle" android:text="Duyệt đơn nghỉ"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnFeatureSucKhoeGrid"
                    style="@style/FeatureItemStyle">
                    <ImageView style="@style/FeatureIconStyle" android:src="@drawable/ic_health"/>
                    <TextView style="@style/FeatureTextStyle" android:text="Sức khỏe / Dặn thuốc"/>
                </LinearLayout>
            </GridLayout>

            <!-- SECTION 3: THỰC ĐƠN -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thực đơn"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:textSize="16sp"/>
                <TextView
                    android:id="@+id/btnViewDetailMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Xem chi tiết"
                    android:textColor="#008B8B"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"/>
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="8dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvMenuDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thực đơn ngày 18/05"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:src="@drawable/ic_cake" />
                    </RelativeLayout>

                    <!-- List danh sách món ăn (Mẫu 1 bữa) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvMealTime"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="07:30"
                            android:textColor="#777777"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvMealType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bữa sáng"
                                android:textColor="#000000"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvMealDishes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cháo sườn sụn, Sữa hạt"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Nút cập nhật khẩu phần -->
                    <Button
                        android:id="@+id/btnUpdateMealPortion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_btn_outline_green"
                        android:text="Cập nhật khẩu phần ăn"
                        android:textColor="#008B8B"
                        style="?android:attr/borderlessButtonStyle" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lịch trình lớp học"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:textSize="16sp"/>
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_calendar"
                    app:tint="#00B16A"/>
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/layoutScheduleTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">
                    <!-- Dynamic timeline items will be added here -->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>
