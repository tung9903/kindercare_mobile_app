<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layout_footer_action"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&lt;  "
                    android:textColor="#101828"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Học phí"
                    android:textColor="#101828"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tuition_banner"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/layout_next_period"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng dư nợ hiện tại"
                        android:textColor="#044E3A"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0 VND"
                        android:textColor="#0F7055"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="✓ Phụ huynh đã hoàn thành tất cả các khoản phí đến Tháng 5/2026."
                        android:textColor="#067647"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_next_period"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_next_period_card"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="#0F7055" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Kỳ thanh toán kế tiếp"
                        android:textColor="#475467"
                        android:textSize="9sp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tháng 06/2026"
                        android:textColor="#101828"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="🕒 Lịch sử giao dịch"
                    android:textColor="#101828"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/spinner_school_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_dropdown_year"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Năm học: 2025 - 2026  ▼"
                    android:textColor="#475467"
                    android:textSize="12sp" />
            </RelativeLayout>

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*"
                android:background="#F9FAFB">

                <TableRow
                    android:background="#EEF1F0"
                    android:paddingVertical="10dp">
                    <TextView android:text="KỲ THU PHÍ" android:gravity="center" android:textStyle="bold" android:textSize="11sp" android:textColor="#475467"/>
                    <TextView android:text="HẠN NỘP" android:gravity="center" android:textStyle="bold" android:textSize="11sp" android:textColor="#475467"/>
                    <TextView android:text="SỐ TIỀN" android:gravity="center" android:textStyle="bold" android:textSize="11sp" android:textColor="#475467"/>
                    <TextView android:text="TRẠNG THÁI" android:gravity="center" android:textStyle="bold" android:textSize="11sp" android:textColor="#475467"/>
                    <TextView android:text="HÀNH ĐỘNG" android:gravity="center" android:textStyle="bold" android:textSize="11sp" android:textColor="#475467"/>
                </TableRow>

                <TableRow android:paddingVertical="14dp" android:background="@android:color/white" android:gravity="center_vertical">
                    <TextView android:text="Tháng\n05/2026" android:gravity="center" android:textSize="12sp" android:textStyle="bold" android:textColor="#101828"/>
                    <TextView android:text="10/05/2026" android:gravity="center" android:textSize="12sp" android:textColor="#667085"/>
                    <TextView android:text="4.500.000 đ" android:gravity="center" android:textSize="12sp" android:textStyle="bold" android:textColor="#0F7055"/>
                    <TextView android:text="ĐÃ\nTHANH TOÁN" android:gravity="center" android:textSize="9sp" android:textStyle="bold" android:textColor="#027A48" android:background="@drawable/bg_badge_status_green" android:padding="4dp" android:layout_marginHorizontal="6dp"/>
                    <ImageView android:src="@android:drawable/ic_menu_agenda" android:layout_width="20dp" android:layout_height="20dp" android:gravity="center" app:tint="#0F7055"/>
                </TableRow>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F4F7"/>

                <TableRow android:paddingVertical="14dp" android:background="@android:color/white" android:gravity="center_vertical">
                    <TextView android:text="Tháng\n04/2026" android:gravity="center" android:textSize="12sp" android:textStyle="bold" android:textColor="#101828"/>
                    <TextView android:text="10/04/2026" android:gravity="center" android:textSize="12sp" android:textColor="#667085"/>
                    <TextView android:text="4.500.000 đ" android:gravity="center" android:textSize="12sp" android:textStyle="bold" android:textColor="#0F7055"/>
                    <TextView android:text="ĐÃ\nTHANH TOÁN" android:gravity="center" android:textSize="9sp" android:textStyle="bold" android:textColor="#027A48" android:background="@drawable/bg_badge_status_green" android:padding="4dp" android:layout_marginHorizontal="6dp"/>
                    <ImageView android:src="@android:drawable/ic_menu_agenda" android:layout_width="20dp" android:layout_height="20dp" android:gravity="center" app:tint="#0F7055"/>
                </TableRow>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F4F7"/>

            </TableLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layout_footer_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        android:padding="16dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_create_invoice"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_create_invoice"
            android:text="💳   Tạo phiếu thu mới"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>