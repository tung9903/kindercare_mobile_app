<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layout_action_buttons"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&lt; "
                    android:textColor="#101828"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhận xét và đánh giá"
                    android:textColor="#101828"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đánh giá quá trình học tập và rèn luyện kỹ năng của học sinh."
                android:textColor="#667085"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nhận xét chung từ giáo viên"
                android:textColor="#101828"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/edt_teacher_comment"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_edittext_comment"
                android:gravity="top|start"
                android:hint="Nhập những nhận xét về thái độ, tinh thần và sự tiến bộ của bé trong tháng này..."
                android:textColorHint="#98A2B3"
                android:textColor="#344054"
                android:padding="16dp"
                android:textSize="14sp"
                android:importantForAutofill="no"
                android:inputType="textMultiLine" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Tối thiểu 50 từ để gửi báo cáo"
                    android:textColor="#98A2B3"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txt_char_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="0 / 500 ký tự"
                    android:textColor="#98A2B3"
                    android:textSize="12sp" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_activity"
                    app:tint="#0F7055" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Chỉ số kỹ năng (Thang điểm 1–10)"
                    android:textColor="#101828"
                    android:textStyle="bold"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/btn_edit_skills"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chỉnh sửa"
                    android:textColor="#0F7055"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"/>
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thể chất (Physical)"
                    android:textColor="#101828"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/edt_skill_physical"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="8"
                    android:textColor="#0F7055"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:gravity="end"
                    android:inputType="number"
                    android:maxLength="2"
                    android:background="@null"
                    android:enabled="false"
                    android:importantForAutofill="no" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhận thức (Cognitive)"
                    android:textColor="#101828"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/edt_skill_cognitive"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="7"
                    android:textColor="#0F7055"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:gravity="end"
                    android:inputType="number"
                    android:maxLength="2"
                    android:background="@null"
                    android:enabled="false"
                    android:importantForAutofill="no" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngôn ngữ (Language)"
                    android:textColor="#101828"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/edt_skill_language"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="9"
                    android:textColor="#0F7055"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:gravity="end"
                    android:inputType="number"
                    android:maxLength="2"
                    android:background="@null"
                    android:enabled="false"
                    android:importantForAutofill="no" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thẩm mỹ (Aesthetic)"
                    android:textColor="#101828"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/edt_skill_aesthetic"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="6"
                    android:textColor="#0F7055"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:gravity="end"
                    android:inputType="number"
                    android:maxLength="2"
                    android:background="@null"
                    android:enabled="false"
                    android:importantForAutofill="no" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tình cảm (Emotional)"
                    android:textColor="#101828"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/edt_skill_emotional"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="8"
                    android:textColor="#0F7055"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:gravity="end"
                    android:inputType="number"
                    android:maxLength="2"
                    android:background="@null"
                    android:enabled="false"
                    android:importantForAutofill="no" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layout_action_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        android:orientation="horizontal"
        android:padding="16dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_save_draft"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_btn_draft_outline"
            android:text="Lưu bản nháp"
            android:textAllCaps="false"
            android:textColor="#344054"
            android:textSize="15sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_submit_report"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_submit_solid"
            android:text="➤  Gửi báo cáo"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>