<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/apk/res/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_student_item"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/tvStudentIndex"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#333333"
        android:textSize="14sp"
        android:textStyle="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="1#" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivStudentAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_avatar_placeholder"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvStudentIndex"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

    <TextView
        android:id="@+id/tvStudentName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#000000"
        android:textSize="15sp"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintBottom_toTopOf="@+id/tvLeaveBadge"
        app:layout_constraintEnd_toStartOf="@+id/tvStatusButton"
        app:layout_constraintStart_toEndOf="@id/ivStudentAvatar"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Lê Thanh Tùng" />

    <TextView
        android:id="@+id/tvLeaveBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Có phép"
        android:textSize="10sp"
        android:textColor="#027A48"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvStudentName"
        app:layout_constraintTop_toBottomOf="@id/tvStudentName"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tvStatusButton"
        android:layout_width="80dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_status_leave"
        android:gravity="center"
        android:text="Nghỉ"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:background="@drawable/bg_status_leave"
        tools:text="Nghỉ" />

</androidx.constraintlayout.widget.ConstraintLayout>