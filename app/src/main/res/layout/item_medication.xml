<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:id="@+id/layoutMainItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top indicator for "Time to drink" -->
        <View
            android:id="@+id/viewStatusIndicator"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#3B82F6"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgStudent"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar"
                    app:shapeAppearanceOverlay="@style/CircleImageStyle" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvStudentName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bé Phạm Trà My"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Chờ tiếp nhận"
                        android:textColor="#D97706"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMedInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#F8FAFC"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvMedName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên thuốc: Siro ho Prospan (5ml)"
                    android:textColor="#475569"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvDosage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Giờ uống: Sau ăn sáng (08:30)"
                    android:textColor="#475569"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvFrequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tần suất: 2 lần/ngày"
                    android:textColor="#475569"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvParentNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Ghi chú PH: Bé bị sốt nhẹ"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvViewEvidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="🖼️ Xem ảnh đơn thuốc/vỏ hộp"
                    android:textColor="#2563EB"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Action Buttons for Pending -->
            <LinearLayout
                android:id="@+id/layoutPendingActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAccept"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✓ Đã nhận thuốc"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#10B981"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReject"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Từ chối"
                    android:textAllCaps="false"
                    android:textColor="#F43F5E"
                    app:cornerRadius="8dp"
                    app:strokeColor="#F43F5E" />
            </LinearLayout>

            <!-- Input area for Completion -->
            <LinearLayout
                android:id="@+id/layoutCompletionArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/edtNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_light_blue"
                    android:backgroundTint="#F8FAFC"
                    android:hint="Ghi chú tình trạng bé (nếu có)..."
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:padding="12dp"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmDone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:padding="12dp"
                    android:text="💊 Đã cho bé uống xong"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:backgroundTint="#3B82F6"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <!-- Display for Completed status -->
            <TextView
                android:id="@+id/tvCompletedNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#E6F4EA"
                android:padding="8dp"
                android:text="Ghi chú: Đã cho uống lúc 11:30"
                android:textColor="#059669"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>