<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:id="@+id/layout_icon_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_icon_container">

        <ImageView
            android:id="@+id/img_noti_icon"
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/ic_warning"
            app:tint="#2F80ED" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txt_noti_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/txt_noti_time"
                android:layout_marginEnd="8dp"
                android:text="Tiêu đề thông báo"
                android:textColor="#101828"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_noti_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="10 phút trước"
                android:textColor="#98A2B3"
                android:textSize="12sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txt_noti_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Nội dung chi tiết của thông báo nằm ở đây..."
            android:textColor="#475467"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:id="@+id/txt_new_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="• Tin nhắn mới"
            android:textColor="#2F80ED"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="visible" />
    </LinearLayout>
</LinearLayout>