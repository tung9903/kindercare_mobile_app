<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp"
    android:background="@android:color/white"
    android:layout_marginBottom="1dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgStudentAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="8dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
        android:src="@drawable/avatar" />

    <TextView
        android:id="@+id/txtStudentName"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Hồ Công Danh"
        android:textColor="@android:color/black"
        android:textSize="13sp"
        android:ellipsize="end"
        android:maxLines="1" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroupMeal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:checkedButton="@+id/btnFull">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFull"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="100%"
            android:textSize="9sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/selector_btn_green" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHalf"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="50%"
            android:textSize="9sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/selector_btn_orange" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLess"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="&lt;25%"
            android:textSize="9sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/selector_btn_red" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <EditText
        android:id="@+id/edtNote"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_weight="1"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_note_input"
        android:hint="Ghi chú..."
        android:paddingHorizontal="8dp"
        android:textColor="@android:color/black"
        android:textSize="12sp"
        android:maxLines="1"
        android:importantForAutofill="no"
        android:inputType="text" />
</LinearLayout>