<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp">

    <LinearLayout
        android:id="@+id/layoutDateBlock"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_square_dark"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvEventMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THÁNG 5"
            android:textColor="#CCCCCC"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvEventDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEventTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Họp phụ huynh đầu năm"
        android:textColor="#333333"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/layoutDateBlock"
        app:layout_constraintTop_toTopOf="@id/layoutDateBlock" />

    <TextView
        android:id="@+id/tvEventTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="🕒 09:00 AM"
        android:textColor="#666666"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvEventTitle"
        app:layout_constraintTop_toBottomOf="@id/tvEventTitle" />

    <TextView
        android:id="@+id/tvEventLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="📍 Phòng đa năng"
        android:textColor="#666666"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvEventTime"
        app:layout_constraintTop_toBottomOf="@id/tvEventTime" />

</androidx.constraintlayout.widget.ConstraintLayout>