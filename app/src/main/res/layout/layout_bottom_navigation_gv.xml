<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardNavGV"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_margin="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:weightSum="5">

        <LinearLayout
            android:id="@+id/btnHoatDong"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavHoatDong"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_activity"
                app:tint="#333333" />
            <TextView
                android:id="@+id/tvNavHoatDong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Hoạt động"
                android:textColor="#333333"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnDanhSachLop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavDanhSachLop"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_class_list"
                app:tint="#333333" />
            <TextView
                android:id="@+id/tvNavDanhSachLop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Lớp học"
                android:textColor="#333333"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnBangDieuKhien"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavBangDieuKhien"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_dashboard_green"
                app:tint="#333333" />
            <TextView
                android:id="@+id/tvNavBangDieuKhien"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Điều khiển"
                android:textColor="#333333"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnDiemDanh"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavDiemDanh"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_attendance"
                app:tint="#333333" />
            <TextView
                android:id="@+id/tvNavDiemDanh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Điểm danh"
                android:textColor="#333333"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnLienLac"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavLienLac"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_mail"
                app:tint="#333333" />
            <TextView
                android:id="@+id/tvNavLienLac"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Hòm thư"
                android:textColor="#333333"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>